# Copy this file to .env and fill in your own API key.
# Never commit your actual .env file (it is gitignored).

# Required — used for chat completions (router/synthesiser/RAG) and
# embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-your-key-here

# Optional — silences ChromaDB's anonymous telemetry pings.
ANONYMIZED_TELEMETRY=False
